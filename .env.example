# ═══════════════════════════════════════
# 光影集 · 壁纸网站 — 环境变量配置
# ═══════════════════════════════════════
# 复制此文件为 .env 并填入实际值
# Railway 部署：在 Dashboard → Variables 中添加

# ── 服务器 ────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT 密钥（生产环境请使用强随机字符串） ──
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-key

# ── Cloudinary 云存储（必填） ──
# 注册地址: https://cloudinary.com/users/register/free
# 免费额度: 25GB 存储 / 25GB 月流量
# Dashboard → Account Details 获取以下三个值
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── 可选：域名（用于 sitemap / robots） ──
# SITE_URL=https://your-app.railway.app

# ── 可选：Redis 缓存（暂未启用） ──
# REDIS_URL=redis://...

# ── 可选：邮件服务（用于密码重置发送邮件） ──
# 支持 SMTP，如 QQ邮箱 / 163 / SendGrid / Resend
# 未配置时：验证码在 API 响应中返回（开发模式）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-smtp-password

# ── 可选：短信服务（用于手机验证码登录） ──
# 推荐：阿里云短信 / 腾讯云短信
# 未配置时：验证码在 API 响应中返回（开发模式）
# SMS_API_KEY=your-sms-api-key
# SMS_API_SECRET=your-sms-api-secret
# SMS_SIGN_NAME=光影集

# ── 可选：微信开放平台（用于微信扫码登录） ──
# 申请地址: https://open.weixin.qq.com
# 未配置时：微信登录按钮自动隐藏
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
# WECHAT_REDIRECT_URI=https://yourdomain.com/api/auth/wechat/callback
